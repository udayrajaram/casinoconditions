{
  "crons": [
    {
      "path": "/api/digest?secret=REPLACE_WITH_YOUR_SECRET",
      "schedule": "0 10 * * 1"
    }
  ],
  "redirects": [
    { "source": "/scarlet-pearl-casino-resort", "destination": "/scarlet-pearl-casino", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/browse", "destination": "/api/browse" },
    { "source": "/bookmarks", "destination": "/api/bookmarks" },
    { "source": "/api/best-time", "destination": "/api/best-time" },
    { "source": "/api/submit-post", "destination": "/api/submit-post" },
    { "source": "/about", "destination": "/api/about" },
    { "source": "/terms", "destination": "/api/terms" },
    { "source": "/privacy", "destination": "/api/privacy" },
    { "source": "/las-vegas-casinos", "destination": "/api/las-vegas-casinos" },
    { "source": "/poker-rooms", "destination": "/api/poker-rooms" },
    { "source": "/api/auth/callback", "destination": "/api/auth-callback" },
    { "source": "/:slug([a-z0-9-]+)", "destination": "/api/casino?slug=:slug" }
  ]
}
